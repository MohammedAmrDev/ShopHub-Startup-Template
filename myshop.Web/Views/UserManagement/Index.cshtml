@model IEnumerable<UserManagementViewModel>
@{
    ViewData["Title"] = "User Management";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <!-- Adjusted column width slightly to accommodate the table properly -->
        <div class="col-md-11 col-lg-10">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0 fw-bold">User Management</h4>
                </div>
                <div class="card-body p-4">

                    <!-- Search Section -->
                    <form method="get" class="mb-4">
                        <div class="input-group">
                            <input type="text" name="searchBy" value="@ViewBag.SearchBy" class="form-control" placeholder="Search by username or email..." />
                            <button type="submit" class="btn btn-primary">Search</button>
                        </div>
                    </form>

                    <!-- Users Table -->
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="fw-semibold">Username</th>
                                    <th class="fw-semibold">Email</th>
                                    <th class="fw-semibold">Current Role</th>
                                    <th class="fw-semibold">Lock Status</th>
                                    <th class="fw-semibold text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model)
                                {
                                    <tr>
                                        <td class="fw-semibold">@user.Username</td>
                                        <td>@user.Email</td>
                                        <td>
                                            <span class="badge bg-primary">@user.Role</span>
                                        </td>
                                        <td>
                                            @if (user.IsLocked)
                                            {
                                                <span class="badge bg-danger">Locked</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex gap-1 flex-wrap justify-content-center">
                                                <!-- 1. Change Role -->
                                                <form asp-action="ToggleRole" asp-route-id="@user.Id" method="post" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                                        Make @(user.Role == "Customer" ? "Admin" : "Customer")
                                                    </button>
                                                </form>

                                                <!-- 2. Lock / Unlock -->
                                                <form asp-action="ToggleLock" asp-route-id="@user.Id" method="post" class="d-inline">
                                                    <button type="submit"
                                                            class="btn btn-sm @(user.IsLocked ? "btn-outline-success" : "btn-outline-warning")">
                                                        @(user.IsLocked ? "Unlock" : "Lock")
                                                    </button>
                                                </form>

                                                <!-- 3. Delete -->
                                                <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                                </form>

                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination Section -->
                    <nav aria-label="Page navigation" class="mt-4">
                        <ul class="pagination justify-content-center mb-0">
                            @if (ViewBag.PageIndex > 0)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-route-pageIndex="@(ViewBag.PageIndex - 1)">Previous</a>
                                </li>
                            }
                            else
                            {
                                <li class="page-item disabled">
                                    <a class="page-link">Previous</a>
                                </li>
                            }
                            <li class="page-item@(ViewBag.PageIndex == 0 ? " active" : "")"><a class="page-link" asp-route-pageIndex="0">1</a></li>

                            @for (int i = 1; i < ViewBag.PagesNum; i++)
                            {                                <li class="page-item @(ViewBag.PageIndex == i ? "active" : "")"><a class="page-link" asp-route-pageIndex="@i">@(i + 1)</a></li>
                            }

                            @if (ViewBag.PageIndex < ViewBag.PagesNum - 1)
                            {
                               <li class="page-item">
                                    <a class="page-link" asp-route-pageIndex="@(ViewBag.PageIndex + 1)">Next</a>
                               </li>
                            }
                            else
                            {
                                <li class="page-item disabled">
                                    <a class="page-link">Next</a>
                                </li>
                            }
                        </ul>
                    </nav>

                </div>
                <div class="card-footer text-center bg-light py-3">
                    <span class="text-muted">Manage your system users securely.</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}